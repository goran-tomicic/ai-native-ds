    "badge": {
      "$schema": "../../schemas/component.schema.json",
      "name": "Badge",
      "version": "0.2.0",
      "status": "experimental",
      "category": "display",
      "description": "A small visual label used to annotate or call out a status, count, or category. For interactive states or filtering, use Tag. For user-generated labels, use Chip.",
      "props": {
        "tone": {
          "type": "enum",
          "values": [
            "neutral",
            "info",
            "success",
            "warning",
            "danger"
          ],
          "default": "neutral",
          "description": "Semantic meaning of the badge, drives palette selection.",
          "guidance": {
            "neutral": "Default for non-semantic labels (categories, counts, generic metadata).",
            "info": "Informational callouts, new features, guidance.",
            "success": "Positive states: completed, verified, active, paid.",
            "warning": "Caution states: pending, needs review, attention required.",
            "danger": "Critical states: failed, expired, blocked, error."
          }
        },
        "size": {
          "type": "enum",
          "values": [
            "sm",
            "md"
          ],
          "default": "md",
          "description": "Physical size. Use sm in dense contexts like tables or cards."
        },
        "children": {
          "type": "ReactNode",
          "description": "Badge label. Keep under 2 words when possible."
        }
      },
      "states": [
        "default"
      ],
      "tokens": {
        "style": "subtle",
        "palette_mapping": {
          "neutral": "color.palette.neutral",
          "info": "color.palette.primary",
          "success": "color.palette.success",
          "warning": "color.palette.warning",
          "danger": "color.palette.danger"
        },
        "slots": {
          "bg": "{palette}.soft",
          "fg": "{palette}.bold"
        },
        "radius": "radius.full",
        "padding.sm": "space.1 space.2",
        "padding.md": "space.1 space.3"
      },
      "accessibility": {
        "role": "status",
        "keyboard": [],
        "requirements": [
          "Color alone must not convey meaning — pair with text label",
          "If badge communicates dynamic state changes, wrap in aria-live region in parent"
        ],
        "contrast": "4.5:1 for text against background"
      },
      "composition": {
        "allowedChildren": [
          "text",
          "Icon"
        ],
        "forbiddenChildren": [
          "Button",
          "Link",
          "Input"
        ],
        "commonParents": [
          "TableCell",
          "Card.Header",
          "ListItem",
          "NavItem"
        ]
      },
      "rules": {
        "do": [
          "Keep labels 1–2 words",
          "Use tone that matches the semantic state (success for completed, not info)",
          "Pair color with text — never rely on color alone"
        ],
        "dont": [
          "Don't use as interactive button — use Tag instead",
          "Don't use for long text or sentences",
          "Don't combine multiple tones in one group without clear reason"
        ]
      },
      "examples": [
        {
          "name": "Status in a table",
          "code": "<Badge tone=\"success\">Active</Badge>",
          "context": "User status column"
        },
        {
          "name": "Warning label",
          "code": "<Badge tone=\"warning\">Pending</Badge>",
          "context": "Order awaiting review"
        },
        {
          "name": "Neutral count",
          "code": "<Badge size=\"sm\">12</Badge>",
          "context": "Notification count"
        }
      ],
      "antiPatterns": [
        {
          "bad": "<Badge tone=\"danger\" onClick={handleClick}>Delete</Badge>",
          "good": "<Button variant=\"destructive\" onClick={handleClick}>Delete</Button>",
          "why": "Badge is a passive label, not an action trigger. Clickable semantics require a Button."
        }
      ],
      "related": {
        "use_instead_when": [
          {
            "component": "Tag",
            "when": "label is interactive (filter, removable)"
          },
          {
            "component": "Chip",
            "when": "label represents user-generated content"
          }
        ]
      }
    },
    "button": {
      "$schema": "../../schemas/component.schema.json",
      "name": "Button",
      "version": "0.1.0",
      "status": "experimental",
      "category": "action",
      "description": "Triggers an action. Use for: submitting forms, confirming dialogs, opening menus, primary actions in views. Not for navigation between pages — use Link. Not for binary toggles — use ToggleButton.",
      "props": {
        "palette": {
          "type": "enum",
          "values": [
            "neutral",
            "primary",
            "danger"
          ],
          "default": "neutral",
          "description": "Semantic intent of the action, drives color treatment.",
          "guidance": {
            "neutral": "Default for most buttons. Use for: cancel, back, secondary actions, tertiary actions. The bulk of buttons in any UI should be neutral.",
            "primary": "The single most important action in a view. Use for: submit, save, continue, confirm. Only one primary button per view, ever.",
            "danger": "Irreversible or destructive actions. Use for: delete, remove, cancel-subscription, reset. Pair with confirmation when consequence is severe."
          }
        },
        "style": {
          "type": "enum",
          "values": [
            "solid",
            "subtle",
            "ghost"
          ],
          "default": "solid",
          "description": "Visual treatment. Determines which palette slots are consumed.",
          "guidance": {
            "solid": "Filled background using palette base color. Highest visual weight. Reserve for primary and destructive actions where emphasis matters.",
            "subtle": "Soft tinted background. Medium visual weight. Default for neutral palette buttons. Use when the action is important but shouldn't dominate.",
            "ghost": "Transparent background, palette-tinted text. Lowest visual weight. Use for tertiary actions, toolbar buttons, dense UIs."
          }
        },
        "size": {
          "type": "enum",
          "values": [
            "sm",
            "md",
            "lg"
          ],
          "default": "md",
          "description": "Physical size. sm in dense contexts (toolbars, table rows). md is default. lg for hero CTAs or mobile primary actions."
        },
        "loading": {
          "type": "boolean",
          "default": false,
          "description": "Replaces button content with a spinner. Disables interaction while loading. Preserves button width to prevent layout shift."
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "description": "Prevents interaction. Reduces opacity to indicate non-interactive state. Disabled appearance is palette-agnostic — neutral, primary, and danger all dim the same way."
        },
        "iconStart": {
          "type": "ReactNode",
          "optional": true,
          "description": "Icon rendered before the label. Pair with text, not as standalone (use IconButton for icon-only)."
        },
        "iconEnd": {
          "type": "ReactNode",
          "optional": true,
          "description": "Icon rendered after the label. Common for: chevrons indicating dropdown, arrows for next/forward."
        },
        "type": {
          "type": "enum",
          "values": [
            "button",
            "submit",
            "reset"
          ],
          "default": "button",
          "description": "Native button type attribute. Use 'submit' inside forms. Default 'button' prevents accidental form submission."
        },
        "children": {
          "type": "ReactNode",
          "description": "Button label. Use a verb describing the action: 'Save changes', 'Delete account'. Avoid 'OK', 'Submit' without context."
        }
      },
      "states": [
        "default",
        "hover",
        "active",
        "focus",
        "disabled",
        "loading"
      ],
      "tokens": {
        "palette_mapping": {
          "neutral": "color.palette.neutral",
          "primary": "color.palette.primary",
          "danger": "color.palette.danger"
        },
        "style_slots": {
          "solid": {
            "bg": "{palette}.base",
            "bg_hover": "{palette}.base-hover",
            "bg_active": "{palette}.base-active",
            "fg": "{palette}.contrast"
          },
          "subtle": {
            "bg": "{palette}.soft",
            "bg_hover": "{palette}.soft-hover",
            "bg_active": "{palette}.soft-active",
            "fg": "{palette}.bold"
          },
          "ghost": {
            "bg": "transparent",
            "bg_hover": "{palette}.subtle",
            "bg_active": "{palette}.soft",
            "fg": "{palette}.bold"
          }
        },
        "effects": {
          "disabled_opacity": "0.4",
          "disabled_pointer_events": "none",
          "transition": "background-color 120ms ease, opacity 120ms ease"
        },
        "shared": {
          "focus_ring": "color.common.border.focus",
          "radius": "radius.md",
          "padding.sm": "space.1 space.3",
          "padding.md": "space.2 space.4",
          "padding.lg": "space.3 space.6",
          "font.sm": "13px",
          "font.md": "14px",
          "font.lg": "16px"
        }
      },
      "accessibility": {
        "role": "button",
        "keyboard": [
          "Enter",
          "Space"
        ],
        "requirements": [
          "Must have accessible label via children or aria-label",
          "Loading state must announce via aria-busy='true'",
          "Disabled state uses aria-disabled (not the disabled attribute) when context requires the button stay focusable for screen reader navigation",
          "Focus ring must be visible — never set outline:none without replacement",
          "Icon-only buttons require aria-label (or use IconButton component)"
        ],
        "contrast": "4.5:1 minimum for text. Solid style buttons meet this via palette/contrast pairing. When disabled, the 0.4 opacity reduces effective contrast — this is intentional and signals non-interactivity."
      },
      "composition": {
        "allowedChildren": [
          "text",
          "Icon",
          "Spinner"
        ],
        "forbiddenChildren": [
          "Button",
          "Link",
          "Input",
          "Select"
        ],
        "commonParents": [
          "ButtonGroup",
          "Form",
          "Dialog.Footer",
          "Card.Actions",
          "Toolbar"
        ]
      },
      "rules": {
        "do": [
          "Use verbs that describe the action: 'Save changes', 'Delete account', 'Send invite'",
          "One primary button per view — the single most important action",
          "Pair destructive buttons with confirmation when consequences are severe",
          "Place primary action on the right in LTR dialog footers",
          "Use type='submit' inside forms; type='button' everywhere else"
        ],
        "dont": [
          "Don't use 'Click here', 'OK', or 'Submit' without context",
          "Don't use multiple primary buttons in the same view",
          "Don't use a button for navigation — use Link",
          "Don't override the disabled opacity — the dim is the affordance",
          "Don't put icons on both sides unless one is decorative (chevron) and one is meaningful"
        ]
      },
      "examples": [
        {
          "name": "Primary submit",
          "code": "<Button palette=\"primary\" style=\"solid\" type=\"submit\">Save changes</Button>",
          "context": "Form footer"
        },
        {
          "name": "Destructive with confirmation",
          "code": "<Button palette=\"danger\" style=\"solid\" onClick={confirmDelete}>Delete account</Button>",
          "context": "Settings page, paired with confirmation dialog"
        },
        {
          "name": "Cancel in dialog",
          "code": "<Button palette=\"neutral\" style=\"subtle\">Cancel</Button>",
          "context": "Dialog footer alongside primary action"
        },
        {
          "name": "Toolbar action",
          "code": "<Button palette=\"neutral\" style=\"ghost\" size=\"sm\" iconStart={<EditIcon />}>Edit</Button>",
          "context": "Dense toolbar, multiple actions"
        },
        {
          "name": "Loading state",
          "code": "<Button palette=\"primary\" style=\"solid\" loading>Saving</Button>",
          "context": "After form submit, before response"
        },
        {
          "name": "Icon-end for dropdown",
          "code": "<Button palette=\"neutral\" style=\"subtle\" iconEnd={<ChevronDownIcon />}>Options</Button>",
          "context": "Trigger for menu or popover"
        }
      ],
      "antiPatterns": [
        {
          "bad": "<Button palette=\"primary\" style=\"solid\">Cancel</Button>",
          "good": "<Button palette=\"neutral\" style=\"subtle\">Cancel</Button>",
          "why": "Cancel is a low-emphasis action. Solid primary reserved for the canonical action of the view."
        },
        {
          "bad": "<Button palette=\"danger\" style=\"solid\" onClick={() => navigate('/profile')}>View Profile</Button>",
          "good": "<Link href=\"/profile\">View Profile</Link>",
          "why": "Navigation belongs to Link. Buttons trigger actions. Destructive palette implies destructive action."
        },
        {
          "bad": "<Button disabled style={{ opacity: 1 }}>Save</Button>",
          "good": "<Button disabled>Save</Button>",
          "why": "Disabled appearance is the visual cue users expect. Overriding opacity keeps the button looking active when it isn't, which is misleading."
        }
      ],
      "related": {
        "use_instead_when": [
          {
            "component": "Link",
            "when": "navigating to another page or view"
          },
          {
            "component": "IconButton",
            "when": "icon-only button, no text label"
          },
          {
            "component": "ToggleButton",
            "when": "binary on/off state"
          },
          {
            "component": "MenuButton",
            "when": "trigger for a menu — has its own composition"
          }
        ]
      }
    },
    "spinner": {
      "$schema": "../../schemas/component.schema.json",
      "name": "Spinner",
      "version": "0.1.0",
      "status": "experimental",
      "category": "feedback",
      "description": "Indicates ongoing background activity. Inherits color from parent via currentColor — meant to be embedded in components like Button (loading state) or used standalone for fetch indicators. For full-page or section loading, use Skeleton instead.",
      "props": {
        "size": {
          "type": "enum",
          "values": [
            "sm",
            "md",
            "lg"
          ],
          "default": "md",
          "description": "Diameter. Match to context: sm inside dense buttons, md for inline indicators, lg for standalone loading states."
        },
        "label": {
          "type": "string",
          "default": "Loading",
          "description": "Accessible label announced to screen readers via aria-label. Override when context demands specificity ('Saving changes', 'Sending')."
        }
      },
      "states": [
        "default"
      ],
      "tokens": {
        "shared": {
          "size.sm": "12px",
          "size.md": "16px",
          "size.lg": "24px",
          "stroke_width": "2px",
          "animation_duration": "750ms"
        },
        "color_inheritance": "currentColor"
      },
      "accessibility": {
        "role": "status",
        "keyboard": [],
        "requirements": [
          "Must have aria-label describing what is loading",
          "When inside a parent component (e.g., Button), parent should set aria-busy='true' instead of relying on Spinner's role"
        ],
        "contrast": "Inherits parent color, which determines contrast"
      },
      "composition": {
        "allowedChildren": [],
        "forbiddenChildren": [
          "text",
          "Icon",
          "Button"
        ],
        "commonParents": [
          "Button",
          "IconButton",
          "Skeleton",
          "Card"
        ]
      },
      "rules": {
        "do": [
          "Use inside components that have their own busy semantics (Button) — let parent communicate state",
          "Match size to context (sm in buttons, md inline, lg standalone)",
          "Provide a meaningful aria-label when used standalone"
        ],
        "dont": [
          "Don't use for content that takes <300ms — flickers and hurts perceived performance",
          "Don't use for full-page loading — Skeleton communicates layout better",
          "Don't override color directly — set color on parent, Spinner inherits"
        ]
      },
      "examples": [
        {
          "name": "Inside Button",
          "code": "<Button loading>Saving</Button>",
          "context": "Button manages spinner via loading prop"
        },
        {
          "name": "Standalone inline",
          "code": "<Spinner label=\"Loading users\" />",
          "context": "Inline indicator next to a section title"
        }
      ],
      "antiPatterns": [
        {
          "bad": "<Spinner color=\"#3b82f6\" />",
          "good": "<div style={{ color: 'var(--color-palette-primary-base)' }}><Spinner /></div>",
          "why": "Spinner inherits via currentColor. Set color on the parent for consistency with the design system."
        }
      ],
      "related": {
        "use_instead_when": [
          {
            "component": "Skeleton",
            "when": "loading content with known layout (lists, cards)"
          },
          {
            "component": "Progress",
            "when": "you can communicate determinate progress"
          }
        ]
      }
    }
  }
}
