{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Component Specification",
  "description": "Machine-readable contract for a design system component",
  "type": "object",
  "required": ["name", "version", "status", "description", "props", "accessibility"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z]+$",
      "description": "PascalCase component name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": ["experimental", "beta", "stable", "deprecated"]
    },
    "category": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "description": "What it is, when to use it, when not to"
    },
    "props": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string" },
          "values": { "type": "array" },
          "default": {},
          "description": { "type": "string" },
          "guidance": { "type": "object" },
          "optional": { "type": "boolean" }
        }
      }
    },
    "states": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tokens": {
      "type": "object",
      "description": "Maps the component's internal slot names to design tokens. Can include style declaration (subtle/solid/outline/ghost), palette mappings, slot templates, and direct token references.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "object" }
        ]
      }
    },
    "accessibility": {
      "type": "object",
      "required": ["role", "requirements"],
      "properties": {
        "role": { "type": "string" },
        "keyboard": { "type": "array", "items": { "type": "string" } },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "contrast": { "type": "string" }
      }
    },
    "composition": {
      "type": "object",
      "properties": {
        "allowedChildren": { "type": "array", "items": { "type": "string" } },
        "forbiddenChildren": { "type": "array", "items": { "type": "string" } },
        "commonParents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "do": { "type": "array", "items": { "type": "string" } },
        "dont": { "type": "array", "items": { "type": "string" } }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "code"],
        "properties": {
          "name": { "type": "string" },
          "code": { "type": "string" },
          "context": { "type": "string" }
        }
      }
    },
    "antiPatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bad", "good", "why"]
      }
    },
    "related": {
      "type": "object"
    },
    "subcomponents": {
      "type": "array",
      "description": "Sub-components that compose with this component (e.g. Input.LeadingIcon). Each subcomponent is a callable JSX element accessed via dot notation.",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Subcomponent name. Used as `ParentName.SubcomponentName` in JSX."
          },
          "description": {
            "type": "string",
            "description": "What the subcomponent does."
          },
          "props": {
            "type": "object",
            "description": "Subcomponent props. Same shape as parent component props."
          },
          "rules": {
            "type": "object",
            "properties": {
              "do":   { "type": "array", "items": { "type": "string" } },
              "dont": { "type": "array", "items": { "type": "string" } }
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name":    { "type": "string" },
                "code":    { "type": "string" },
                "context": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}