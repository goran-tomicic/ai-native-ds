{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Component Specification",
  "description": "Machine-readable contract for a design system component",
  "type": "object",
  "required": ["name", "version", "status", "description", "props", "accessibility"],

  "$defs": {
    "propDescriptor": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "values": { "type": "array" },
        "default": {},
        "description": { "type": "string" },
        "guidance": { "type": "object" },
        "optional": { "type": "boolean" },
        "shape": {
          "type": "object",
          "description": "For object-typed props, describes nested keys. Each key is itself a propDescriptor.",
          "additionalProperties": { "$ref": "#/$defs/propDescriptor" }
        }
      }
    },
    "propGroup": {
      "type": "object",
      "description": "A grouped set of props for imperative or multi-piece components (e.g. ToastProvider, useToast, Toast as three pieces of one component). Each entry inside is itself a propDescriptor.",
      "additionalProperties": { "$ref": "#/$defs/propDescriptor" }
    }
  },

  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z]+$",
      "description": "PascalCase component name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": ["experimental", "beta", "stable", "deprecated"]
    },
    "category": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "description": "What it is, when to use it, when not to"
    },
    "props": {
      "type": "object",
      "description": "Component props. Each value is either a single prop descriptor (declarative components) or a group of prop descriptors keyed by piece name (imperative/multi-piece components like Toast).",
      "additionalProperties": {
        "anyOf": [
          { "$ref": "#/$defs/propDescriptor" },
          { "$ref": "#/$defs/propGroup" }
        ]
      }
    },
    "states": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tokens": {
      "type": "object",
      "description": "Maps the component's internal slot names to design tokens.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "object" }
        ]
      }
    },
    "accessibility": {
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "keyboard": { "type": "array", "items": { "type": "string" } },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "contrast": { "type": "string" }
      }
    },
    "composition": {
      "type": "object",
      "description": "How this component composes with others. Imperative components may add provider/hook placement guidance here.",
      "properties": {
        "allowedChildren": { "type": "array", "items": { "type": "string" } },
        "forbiddenChildren": { "type": "array", "items": { "type": "string" } },
        "commonParents": { "type": "array", "items": { "type": "string" } },
        "subcomponentOrdering": { "type": "string" },
        "providerPlacement": { "type": "string" },
        "hookUsage": { "type": "string" }
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "do": { "type": "array", "items": { "type": "string" } },
        "dont": { "type": "array", "items": { "type": "string" } }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "code"],
        "properties": {
          "name": { "type": "string" },
          "code": { "type": "string" },
          "context": { "type": "string" }
        }
      }
    },
    "antiPatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["bad", "good", "why"]
      }
    },
    "related": {
      "type": "object"
    },
    "subcomponents": {
      "type": "array",
      "description": "Sub-components accessed via dot notation (e.g. Input.LeadingIcon).",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "props": {
            "type": "object",
            "additionalProperties": { "$ref": "#/$defs/propDescriptor" }
          },
          "rules": {
            "type": "object",
            "properties": {
              "do":   { "type": "array", "items": { "type": "string" } },
              "dont": { "type": "array", "items": { "type": "string" } }
            }
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name":    { "type": "string" },
                "code":    { "type": "string" },
                "context": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "architecture": {
      "type": "object",
      "description": "For imperative or multi-piece components: describes the coordinated pieces (provider, hook, visual element).",
      "properties": {
        "summary": { "type": "string" },
        "pieces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" }
            }
          }
        }
      }
    },

    "useToastAPI": {
      "type": "object",
      "description": "Documents the API surface of a hook-returned object (currently only used by Toast's useToast). Considered for promotion to a generic 'hookAPI' field if other hook-based components emerge.",
      "properties": {
        "description": { "type": "string" },
        "methods": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["signature", "description"],
            "properties": {
              "signature": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },

    "behavior": {
      "type": "object",
      "description": "Free-form behavioral notes that don't fit prop or state definitions (queue, timing, animation lifecycles). Used by imperative components.",
      "additionalProperties": { "type": "string" }
    }
  }
}